# Zendesk Credentials - Set 1
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@example.com
ZENDESK_API_TOKEN=your-api-token

# Zendesk Credentials - Set 2
ZENDESK_SUBDOMAIN_2=your-second-subdomain
ZENDESK_EMAIL_2=your-second-email@example.com
ZENDESK_API_TOKEN_2=your-second-api-token

# Priority Field IDs (Custom field ID for ticket priority in each Zendesk instance)
# For credential set 1, use either PRIORITY_FIELD_ID or PRIORITY_FIELD_ID_1
PRIORITY_FIELD_ID=360047533253
PRIORITY_FIELD_ID_1=360047533253

# For credential set 2
PRIORITY_FIELD_ID_2=123456789012

# Gemini AI Configuration
GOOGLE_API_KEY=your-google-api-key

# Email Configuration (Gmail SMTP)
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_TO=recipient1@example.com,recipient2@example.com

# Optional: Credential set selection (1 or 2)
# If not set, will auto-detect or require explicit --credential-set flag
# ZENDESK_CREDENTIAL_SET=1
